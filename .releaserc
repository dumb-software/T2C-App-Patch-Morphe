{
  "branches": [
    "main",
    {
      "name": "dev",
      "prerelease": "alpha"
    }
  ],
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "preset": "angular",
        "releaseRules": [
          { "type": "build", "release": "patch" },
          { "type": "chore", "release": "patch" },
          { "type": "fix", "release": "patch" },
          { "type": "feat", "release": "minor" }
        ]
      }
    ],
    "@semantic-release/release-notes-generator",

    [
      "@MorpheApp/changelog",
      {
        "releaseJson": {
          "path": "patches-bundle.json",
          "downloadUrlTemplate": "https://github.com/${owner}/${repo}/releases/download/v${version}/patches-${version}.mpp",
          "signatureUrlTemplate": "https://github.com/${owner}/${repo}/releases/download/v${version}/patches-${version}.mpp.asc"
        }
      }
    ],

    "gradle-semantic-release-plugin",

    [
      "@semantic-release/exec",
      {
        "prepareCmd": "jq --arg v \"${nextRelease.version}\" '.version=$v' patches-list.json > patches-list.tmp.json && mv patches-list.tmp.json patches-list.json"
      }
    ],

    [
      "@semantic-release/git",
      {
        "assets": [
          "CHANGELOG.md",
          "gradle.properties",
          "patches-bundle.json",
          "patches-list.json"
        ],
        "message": "chore(release): v${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],

    [
      "@semantic-release/github",
      {
        "assets": [
          {
            "path": "patches/build/libs/patches-*.mpp"
          }
        ],
        "successComment": false
      }
    ],

    [
      "@saithodev/semantic-release-backmerge",
      {
        "backmergeBranches": [
          { "from": "main", "to": "dev" }
        ],
        "clearWorkspace": true
      }
    ]
  ]
}
